MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net
MONGO_DB_NAME=wajeeh_kb
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=models/embedding-001
TOP_K_RESULTS=5
CHUNK_SIZE=500
CHUNK_OVERLAP=50
VIDEO_CHUNK_SIZE=600
VIDEO_CHUNK_OVERLAP=80
VIDEO_SUMMARY_MAX_WORDS=3000
FAISS_INDEX_PATH=faiss_index
ADMIN_EMAIL=admin@wajeeh.com
ADMIN_PASSWORD=changeme
JWT_SECRET=change-this-to-a-random-secret

# Optional: S3-compatible storage (MinIO, AWS S3, etc.) for panel image uploads
# When unset or incomplete, uploads stay on local disk under /uploads
S3_ENABLED=true
S3_ENDPOINT=localhost
S3_PORT=9000
S3_USE_SSL=false
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=wajeeh-kb
S3_REGION=
S3_KEY_PREFIX=kb
# Public URL prefix so kb-portal can render images (must match how objects are reachable)
S3_PUBLIC_URL_BASE=http://localhost:9000/wajeeh-kb
# Set to false only for dev TLS (self-signed)
S3_REJECT_UNAUTHORIZED=true
# Bucket CORS must allow PUT from the panel origin for browser uploads.
# Panel: set NEXT_PUBLIC_MEDIA_PUBLIC_BASE_URL to the same value as S3_PUBLIC_URL_BASE so re-saves skip re-uploading images.
